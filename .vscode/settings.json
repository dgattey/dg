{
	// No workspace tsdk pin: `typescript` resolves to @typescript/typescript6, which
	// is an API-only bridge for Next's build-time check and ships no tsserver. The
	// editor uses its own bundled TypeScript instead. Run "Disable TypeScript 7
	// Language Server" if you need the `next` language-service plugin, which only
	// loads under a TypeScript 6 language server.
	"editor.formatOnSave": true,
	"editor.codeActionsOnSave": {
		"source.fixAll.biome": "explicit",
		"source.action.useSortedKeys.biome": "explicit",
		"source.action.useSortedProperties.biome": "explicit",
		"source.action.useSortedAttributes.biome": "explicit",
		"source.action.organizeImports.biome": "explicit"
	},
	"editor.defaultFormatter": "biomejs.biome",
	"[javascript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[typescript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[typescriptreact]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[json]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"workbench.preferredDarkColorTheme": "Nebula Oni (Cerberus)",
	"workbench.preferredLightColorTheme": "Ayu Light Bordered",
	"jest.jestCommandLine": "turbo test --"
}
